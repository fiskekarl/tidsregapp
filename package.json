{
  "name": "time-registration",
  "version": "1.0.0",
  "description": "SAP BTP Kiosk Tidsregistrering for produktionsmedarbejdere",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "cds build --production",
    "deploy": "mbt build && cf deploy mta_archives/time-registration_1.0.0.mtar"
  },
  "dependencies": {
    "@sap-cloud-sdk/http-client": "^3",
    "@sap/cds": "^8",
    "@sap/xssec": "^4",
    "express": "^4",
    "passport": "^0.7"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8",
    "sqlite3": "^5"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana-cloud",
        "[development]": {
          "kind": "sqlite",
          "credentials": {
            "database": ":memory:"
          }
        }
      },
      "uaa": {
        "kind": "xsuaa"
      },
      "s4": {
        "kind": "odata",
        "model": "srv/external/CATS_API",
        "[development]": {
          "kind": "odata-v2-mock"
        }
      },
      "destinations": {
        "kind": "destinations"
      }
    },
    "features": {
      "assert_integrity": "db"
    }
  }
}
